{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "predev": "yarn i18n:compile",
    "build": "next build",
    "prebuild": "yarn i18n:compile",
    "start": "next start",
    "lint": "biome check .",
    "prelint": "yarn i18n:compile",
    "lint:fix": "biome lint --write .",
    "lint:check": "biome check .",
    "prelint:check": "yarn i18n:compile",
    "format:fix": "biome format --write .",
    "format:check": "biome format .",
    "i18n:extract": "lingui extract --clean",
    "i18n:compile": "lingui compile --typescript",
    "deploy": "yarn build && serverless deploy --stage production",
    "deploy:dev": "yarn build && serverless deploy --stage dev"
  },
  "dependencies": {
    "@lingui/core": "^5.9.4",
    "@lingui/react": "^5.9.4",
    "@radix-ui/react-slot": "1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "latest",
    "lucide-react": "^0.454.0",
    "next": "16.2.2",
    "next-themes": "latest",
    "react": "19",
    "react-dom": "19",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@lingui/cli": "^5.9.4",
    "@lingui/format-po": "^5.9.4",
    "@lingui/swc-plugin": "^5.11.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5",
    "serverless": "^3",
    "serverless-cloudfront-invalidate": "^1.12.2",
    "serverless-s3-sync": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
